# 管理密钥，用于 API 认证
ADMIN_KEY=change-me-now

# 服务端口
PORT=7860

# Worker 进程数
WORKERS=1

# 引擎模式：httpx（快速直连）、browser（浏览器指纹）或 hybrid（混合）
ENGINE_MODE=hybrid

# 浏览器池大小
BROWSER_POOL_SIZE=2

# 每个账号最大并发请求数
MAX_INFLIGHT=1

# 账号请求最小间隔（毫秒）
ACCOUNT_MIN_INTERVAL_MS=1200

# 请求抖动最小值（毫秒）
REQUEST_JITTER_MIN_MS=120

# 请求抖动最大值（毫秒）
REQUEST_JITTER_MAX_MS=360

# 普通请求最大重试次数
MAX_RETRIES=2

# 工具调用最大重试次数
TOOL_MAX_RETRIES=2

# 空响应重试次数
EMPTY_RESPONSE_RETRIES=1

# 限流基础冷却时间（秒）
RATE_LIMIT_BASE_COOLDOWN=600

# 限流最大冷却时间（秒）
RATE_LIMIT_MAX_COOLDOWN=3600

# 流式响应保活间隔（秒）
STREAM_KEEPALIVE_INTERVAL=5

# 账号配置文件路径
ACCOUNTS_FILE=/workspace/data/accounts.json

# 用户配置文件路径
USERS_FILE=/workspace/data/users.json

# 捕获数据文件路径
CAPTURES_FILE=/workspace/data/captures.json

# 系统配置文件路径
CONFIG_FILE=/workspace/data/config.json

# 注册日志文件路径
REGISTER_LOG_FILE=/workspace/data/register_logs.json

# 注册日志归档目录
REGISTER_LOG_ARCHIVE_DIR=/workspace/data/register_logs

# 注册日志文件最大字节数
REGISTER_LOG_MAX_BYTES=262144

# 注册日志切片大小
REGISTER_LOG_SLICE_SIZE=200

# 注册日志归档保留数量
REGISTER_LOG_ARCHIVE_KEEP=20

# 注册日志分页大小
REGISTER_LOG_PAGE_SIZE=20

# 日志级别：DEBUG、INFO、WARNING、ERROR
LOG_LEVEL=INFO

# 上下文内联最大字符数（超过则转为文件）
CONTEXT_INLINE_MAX_CHARS=4000

# 上下文强制文件化最大字符数
CONTEXT_FORCE_FILE_MAX_CHARS=10000

# 上下文附件 TTL（秒）
CONTEXT_ATTACHMENT_TTL_SECONDS=1800

# 上下文上传解析超时（秒）
CONTEXT_UPLOAD_PARSE_TIMEOUT_SECONDS=60

# 上下文生成文件目录
CONTEXT_GENERATED_DIR=/workspace/data/context_files

# 上下文缓存文件路径
CONTEXT_CACHE_FILE=/workspace/data/context_cache.json

# 已上传文件记录路径
UPLOADED_FILES_FILE=/workspace/data/uploaded_files.json

# 会话亲和性配置文件路径
CONTEXT_AFFINITY_FILE=/workspace/data/session_affinity.json

# 上下文生成文件允许的扩展名（逗号分隔）
CONTEXT_ALLOWED_GENERATED_EXTS=txt,md,json,log

# 用户上传文件允许的扩展名（逗号分隔）
CONTEXT_ALLOWED_USER_EXTS=txt,md,json,log,xml,yaml,yml,csv,html,css,py,js,ts,java,c,cpp,cs,php,go,rb,sh,zsh,ps1,bat,cmd,pdf,doc,docx,ppt,pptx,xls,xlsx,png,jpg,jpeg,webp,gif,tiff,bmp,svg
